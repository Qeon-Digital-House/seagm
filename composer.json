{
    "name": "rrq/seagm",
    "description": "Laravel package for SeaGM API integration - products, transactions, and balance management",
    "keywords": [
        "laravel",
        "seagm",
        "api",
        "game-topup",
        "voucher",
        "digital-product"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Rrq\\Seagm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rrq\\Seagm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rrq\\Seagm\\SeaGmServiceProvider"
            ],
            "aliases": {
                "SeaGm": "Rrq\\Seagm\\Facades\\SeaGmFacade"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
